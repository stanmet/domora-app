# База данных (Supabase / RDS / Neon)
DATABASE_URL="postgresql://user:pass@host:5432/domora"

# Приложение
APP_URL="https://domora.vercel.app"
ENCRYPTION_KEY="32-байтовый ключ для адресов, openssl rand -hex 32"

# Supabase Auth (dashboard.supabase.com -> Project Settings -> API)
# SUPABASE_SERVICE_ROLE_KEY нужен ещё и для загрузки фото портфолио в Storage
# (публичный бакет "portfolio" создаётся автоматически при первой загрузке).
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# Stripe (dashboard.stripe.com -> Developers -> API keys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Вебхуки Stripe создаются приложением автоматически, секреты НЕОБЯЗАТЕЛЬНЫ
# (подлинность события проверяется перечитыванием из Stripe API).
# Детали: docs/stripe-webhook-setup.md. Локально: секрет из stripe listen.
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# Автоперевод пользовательских текстов (профили, услуги, задачи, отклики, чат).
# Бесплатный ключ: deepl.com/pro-api (план "DeepL API Free"). Без ключа
# приложение просто показывает оригинал, переводы отключаются.
DEEPL_API_KEY=""

# Email-уведомления (resend.com -> API Keys). Без этих переменных письма просто
# не отправляются, в приложении остаются только уведомления внутри сайта.
# EMAIL_FROM должен быть на подтверждённом в Resend домене, например
# "Domora <noreply@domora.ie>".
RESEND_API_KEY=""
EMAIL_FROM=""

# Прокси-телефоны (этап 2)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
