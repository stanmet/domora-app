# База данных (Supabase / RDS / Neon)
# DATABASE_URL - пул соединений (Supabase pgbouncer, порт 6543), используется приложением в рантайме.
# Для Supabase добавьте к строке ?pgbouncer=true
DATABASE_URL="postgresql://user:pass@host:6543/domora?pgbouncer=true"
# DIRECT_URL - прямое соединение (порт 5432) для миграций (prisma migrate deploy на сборке Vercel).
# Для Supabase: Project Settings -> Database -> Connection string -> вкладка "Direct connection".
DIRECT_URL="postgresql://user:pass@host:5432/domora"

# Приложение
APP_URL="https://domora.vercel.app"
ENCRYPTION_KEY="32-байтовый ключ для адресов, openssl rand -hex 32"

# Supabase Auth (dashboard.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# Stripe (dashboard.stripe.com -> Developers -> API keys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Вебхуки Stripe создаются приложением автоматически, секреты НЕОБЯЗАТЕЛЬНЫ
# (подлинность события проверяется перечитыванием из Stripe API).
# Детали: docs/stripe-webhook-setup.md. Локально: секрет из stripe listen.
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# Перевод чата
DEEPL_API_KEY=""

# Прокси-телефоны (этап 2)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
