# База данных (Supabase)
# ВАЖНО для Vercel/serverless: используйте ПУЛОВОЕ соединение Supabase (pgBouncer,
# порт 6543) как DATABASE_URL, иначе под нагрузкой закончатся соединения к базе.
# Supabase -> Project Settings -> Database -> Connection string -> "Transaction pooler".
DATABASE_URL="postgresql://postgres.xxxx:pass@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# ПРЯМОЕ соединение (порт 5432) - только для миграций/db push (prisma). Возьмите
# "Session pooler"/"Direct connection" из того же экрана. Локально можно не задавать.
DIRECT_URL="postgresql://postgres.xxxx:pass@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Приложение
APP_URL="https://domora.vercel.app"
ENCRYPTION_KEY="32-байтовый ключ для адресов, openssl rand -hex 32"

# Cron (Vercel Cron). ОБЯЗАТЕЛЬНО задайте секрет в проде: без него эндпоинт
# /api/cron закрыт (fail-closed). Vercel передаёт его в заголовке Authorization.
CRON_SECRET=""

# Supabase Auth (dashboard.supabase.com -> Project Settings -> API)
# SUPABASE_SERVICE_ROLE_KEY нужен ещё и для загрузки фото портфолио в Storage
# (публичный бакет "portfolio" создаётся автоматически при первой загрузке).
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# Stripe (dashboard.stripe.com -> Developers -> API keys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Вебхуки Stripe создаются приложением автоматически, секреты НЕОБЯЗАТЕЛЬНЫ
# (подлинность события проверяется перечитыванием из Stripe API).
# Детали: docs/stripe-webhook-setup.md. Локально: секрет из stripe listen.
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# Автоперевод пользовательских текстов (профили, услуги, задачи, отклики, чат).
# Бесплатный ключ: deepl.com/pro-api (план "DeepL API Free"). Без ключа
# приложение просто показывает оригинал, переводы отключаются.
DEEPL_API_KEY=""

# Email-уведомления (resend.com -> API Keys). Без этих переменных письма просто
# не отправляются, в приложении остаются только уведомления внутри сайта.
# EMAIL_FROM должен быть на подтверждённом в Resend домене, например
# "Domora <noreply@domora.ie>".
RESEND_API_KEY=""
EMAIL_FROM=""

# Аналитика Plausible (без cookи, GDPR-friendly). Укажите домен сайта, тогда
# подключится счётчик и продуктовые события (регистрация, вход, заказ, оплата,
# отмена, отзыв). Без переменной аналитика просто отключена.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Прокси-телефоны (этап 2)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# Тестовые пользователи (AI-генерация текстов профилей). Провайдер и ключ.
# TEST_AI_PROVIDER: anthropic | local. Без ключа модуль работает на встроенном генераторе.
TEST_AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY="sk-ant-..."

# Дополнительные AI-провайдеры для генерации тестовых профилей (по желанию).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
