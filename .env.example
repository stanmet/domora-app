# Domora — пример переменных окружения.
# Скопируй этот файл в .env.local и заполни своими значениями.
# Реальные ключи в git не попадают (.env* уже в .gitignore).
# На Vercel те же переменные задаются в Project Settings -> Environment Variables.

# ── База данных (Supabase Postgres) ────────────────────────────────────────
# Строка подключения из Supabase: Project Settings -> Database -> Connection string.
# Используй пулер (порт 6543) для рантайма приложения.
DATABASE_URL="postgresql://postgres:ПАРОЛЬ@ХОСТ:6543/postgres?pgbouncer=true"

# ── Supabase (аутентификация) ──────────────────────────────────────────────
# Project Settings -> API. URL и anon-ключ публичные (уходят в браузер).
NEXT_PUBLIC_SUPABASE_URL="https://ТВОЙ-ПРОЕКТ.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
# Service-role ключ секретный, только на сервере. Никогда не показывать в браузере.
SUPABASE_SERVICE_ROLE_KEY="ey..."

# ── Адрес приложения ───────────────────────────────────────────────────────
# Полный публичный адрес сайта (для ссылок в письмах, метаданных, return_url).
APP_URL="https://domora-app-beta.vercel.app"
NEXT_PUBLIC_APP_URL="https://domora-app-beta.vercel.app"

# ── Stripe (платежи) ───────────────────────────────────────────────────────
# Dashboard -> Developers -> API keys. Publishable уходит в браузер, secret — нет.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Секреты подписи вебхуков. Необязательны: приложение перепроверяет события
# запросом в Stripe. Если заданы — подпись проверяется без лишнего запроса.
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."

# ── Cron (регулярные задачи денежного цикла) ───────────────────────────────
# Свой секрет: Vercel Cron шлёт его в заголовке, чтобы /api/cron нельзя было
# дёрнуть снаружи. Придумай длинную случайную строку.
CRON_SECRET=""

# ── Шифрование чувствительных данных ───────────────────────────────────────
# Ключ для шифрования персональных данных в базе. Длинная случайная строка.
ENCRYPTION_KEY=""

# ── Почта (уведомления) ────────────────────────────────────────────────────
# Resend: отправка писем. https://resend.com -> API Keys.
RESEND_API_KEY="re_..."
# Адрес отправителя, подтверждённый в Resend.
EMAIL_FROM="Domora <noreply@твой-домен>"

# ── Автоперевод чата и текстов (нужен один из провайдеров) ──────────────────
# DeepL — основной переводчик. https://www.deepl.com/pro-api
DEEPL_API_KEY=""
# Запасные ИИ-провайдеры для перевода/подсказок (по желанию).
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
# Какой ИИ-провайдер использовать для тестовых сценариев: anthropic | openai | gemini | local
TEST_AI_PROVIDER="local"

# ── Аналитика (по желанию) ─────────────────────────────────────────────────
# Домен в Plausible; если пусто — скрипт аналитики не подключается.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ── Юр. подпись в футере (по желанию) ──────────────────────────────────────
NEXT_PUBLIC_COMPANY_LEGAL=""
